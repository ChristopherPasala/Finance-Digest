# ============================================================
# Finance Digest Bot — Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- DISCORD ----
# Get from: https://discord.com/developers/applications → Your App → Bot → Token
DISCORD_TOKEN=
# Right-click your server → Copy Server ID (enable Developer Mode in Discord settings)
DISCORD_GUILD_ID=

# Right-click the channel where briefings should be posted → Copy Channel ID
BRIEFING_CHANNEL_ID=

# ---- OLLAMA LLM ----
# Default: http://localhost:11434/v1 (Ollama's built-in OpenAI-compatible API)
OLLAMA_API_URL=http://localhost:11434/v1

# Model name — must match a model you've pulled with: ollama pull <model>
# Examples: qwen2.5:7b | llama3.1:8b | qwen2.5:14b
OLLAMA_MODEL=qwen2.5:7b

# ---- FINANCIAL DATA APIs ----
# Alpha Vantage — free tier: 25 req/day
# Get key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# Finnhub — free tier: 60 req/min
# Get key at: https://finnhub.io/register
FINNHUB_KEY=

# ---- BRIEFING SCHEDULE ----
# Time for both the daily watchlist briefing and weekly portfolio deep dive (24-hour format)
BRIEFING_TIME=07:00

# IANA timezone string
# Examples: America/New_York | America/Chicago | America/Los_Angeles | Europe/London
BRIEFING_TIMEZONE=America/New_York

# Day of week for the weekly portfolio deep dive
# Options: mon | tue | wed | thu | fri | sat | sun
PORTFOLIO_BRIEFING_DAY=mon

# Day of week for the autonomous market scan (LLM-driven universe from news)
# Options: mon | tue | wed | thu | fri | sat | sun
MARKET_SCAN_DAY=sun

# How many top discoveries to include in the market scan HTML report
MARKET_SCAN_TOP_N=10

# ---- WEB REPORT SERVER ----
# Host and port for the local HTTP server that serves scan report pages
WEB_HOST=127.0.0.1
WEB_PORT=8080

# Public base URL (set this if you are using Cloudflare Tunnel or any reverse proxy)
# Example: https://reports.yourdomain.com
# Leave blank to use http://<WEB_HOST>:<WEB_PORT> (local-only)
WEB_PUBLIC_URL=

# Secret token embedded in report URLs (128-bit security)
# Leave blank to auto-generate a new token on each bot restart (links break on restart)
# Set a fixed value to keep links stable across restarts:
#   python -c "import secrets; print(secrets.token_hex(16))"
WEB_SECRET_TOKEN=

# ---- STORAGE ----
DB_PATH=./finance_digest.db
LOG_PATH=./logs/finance_digest.log

# ---- SEC EDGAR ----
# Required by EDGAR's terms of service — identify your application
# Format: AppName/Version contact@email.com
SEC_USER_AGENT=christopher.pasala@gmail.com

# ---- LIMITS ----
MAX_DISCORD_EMBEDS_PER_BRIEFING=20
